# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------


def main() -> None:
    # Shared flags available on all subcommands
    common = argparse.ArgumentParser(add_help=False)
    common.add_argument(
        "--json", action="store_true", help="Output as JSON (for agents / piping)"
    )
    common.add_argument("--db", type=Path, default=None, help="Override database path")
    common.add_argument(
        "--limit", type=int, default=None, help=f"Row limit (default {DEFAULT_LIMIT})"
    )

    parser = argparse.ArgumentParser(
        prog="amie",
        description="Query local Amie.app recording & transcription data.",
        parents=[common],
    )
    parser.add_argument(
        "--agent-help",
        action="store_true",
        help="Print machine-readable documentation for AI agents and exit.",
    )

    sub = parser.add_subparsers(dest="command")

    # list
    sub.add_parser("list", help="Recent recordings", parents=[common])

    # latest
    sub.add_parser(
        "latest", help="Most recent recording with summary", parents=[common]
    )

    # show
    p_show = sub.add_parser(
        "show", help="Full detail for one recording", parents=[common]
    )
    p_show.add_argument(
        "recording", help="Recording ID, short ID prefix, or numeric index from `list`"
    )

    # transcript
    p_trans = sub.add_parser(
        "transcript", help="Segment-by-segment transcript", parents=[common]
    )
    p_trans.add_argument(
        "recording", help="Recording ID, short ID prefix, or numeric index"
    )

    # summary
    p_sum = sub.add_parser("summary", help="Short + long summary", parents=[common])
    p_sum.add_argument(
        "recording", help="Recording ID, short ID prefix, or numeric index"
    )

    # speakers
    p_spk = sub.add_parser("speakers", help="Speaker roster", parents=[common])
    p_spk.add_argument(
        "recording", help="Recording ID, short ID prefix, or numeric index"
    )

    # search
    p_search = sub.add_parser(
        "search",
        help="Full-text search across titles, summaries, transcripts",
        parents=[common],
    )
    p_search.add_argument("query", help="Search query")

    # span
    p_span = sub.add_parser(
        "span", help="Recordings within a date range", parents=[common]
    )
    p_span.add_argument("start_date", help="Start date (YYYY-MM-DD, inclusive)")
    p_span.add_argument("end_date", help="End date (YYYY-MM-DD, inclusive)")

    args = parser.parse_args()

    # Agent-facing help (checked before command dispatch)
    if args.agent_help:
        _agent_help()
        return

    # Default to `list` if no subcommand given
    if not args.command:
        args.command = "list"

    commands = {
        "list": cmd_list,
        "latest": cmd_latest,
        "show": cmd_show,
        "transcript": cmd_transcript,
        "summary": cmd_summary,
        "speakers": cmd_speakers,
        "search": cmd_search,
        "span": cmd_span,
    }

    commands[args.command](args)


if __name__ == "__main__":
    main()
