# Run a command and eval its stdout as zsh completion code.
# Strips the leading `#compdef <name>` header that errors under eval
# (interactive_comments doesn't apply inside eval'd strings in zsh).
# Silently skips if the named binary isn't on PATH.
_eval_completion() {
  local cmd=$1; shift
  command -v "$cmd" >/dev/null || return
  eval "$("$@" 2>/dev/null | sed '/^#compdef/d')"
}

