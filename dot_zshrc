# zoxide
function __zoxide_list_ghq_missing {
  (($+commands[ghq])) || return 0

  comm -13 \
    <(zoxide query --list | sort -u) \
    <(ghq list -p | sort -u)
}

function __zoxide_add_ghq_missing {
  (($+commands[ghq])) || return 0

  local -a missing
  missing=("${(@f)$(__zoxide_list_ghq_missing)}")
  ((${#missing[@]})) || return 0

  zoxide add -- "${missing[@]}"
}

function __jay_init_zoxide {
  # Initialize normally to keep zoxide's z completion, then override z/zi
  # so they can seed zoxide with ghq repos first.
  unalias zi 2>/dev/null || true
  eval "$(zoxide init zsh)"

  function z {
    if [[ "$" -gt 0 ]] && ! { [[ "$" -eq 1 ]] && { [[ -d "$1" ]] || [[ "$1" = "-" ]] || [[ "$1" =~ ^[-+][0-9]$ ]]; }; }; then
      __zoxide_add_ghq_missing
    fi
    __zoxide_z "$@"
  }

  function zi {
    __zoxide_add_ghq_missing
    __zoxide_zi "$@" || true
  }
}

zinit ice lucid wait"0a" depth"1" from="gh-r" as="program" atload'__jay_init_zoxide'
zinit light ajeetdsouza/zoxide

